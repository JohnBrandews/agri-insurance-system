datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  role            String    @default("FARMER")
  name            String
  profileImageUrl String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  lastLogin       DateTime?

  company   InsuranceCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?

  managedAgents Agent[]
  farmerProfile Farmer?
}

model InsuranceCompany {
  id            String         @id @default(cuid())
  name          String
  status        String         @default("PENDING") // PENDING, APPROVED, REJECTED
  users         User[]
  policies      Policy[]
  subscriptions Subscription[]
  agents        Agent[]
  createdAt     DateTime       @default(now())
}

model Subscription {
  id        String           @id @default(cuid())
  amount    Float
  status    String // ACTIVE, EXPIRED
  companyId String
  company   InsuranceCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
}

model Agent {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId         String
  company           InsuranceCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  region            String
  phone             String?
  idNumber          String?
  status            String           @default("ACTIVE") // ACTIVE, SUSPENDED
  farmersRegistered Farmer[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @default(now()) @updatedAt
}

model Farmer {
  id          String       @id @default(cuid())
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String?
  agentId     String
  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  farms       Farm[]
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
}

model Farm {
  id                 String            @id @default(cuid())
  farmerId           String
  farmer             Farmer            @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  locationName       String
  acreage            Float
  cropType           String
  polygonCoordinates String // Stored as JSON string
  latitude           Float?
  longitude          Float?
  status             String            @default("HEALTHY") // HEALTHY, RISK, TRIGGERED
  imageUrl           String?
  enrollments        Enrollment[]
  rainfallReadings   RainfallReading[]
  triggerEvents      TriggerEvent[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt
}

model Policy {
  id                String           @id @default(cuid())
  companyId         String
  company           InsuranceCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name              String
  cropType          String
  region            String
  rainfallThreshold Float // Threshold in mm
  premiumRate       Float
  payoutRate        Float
  seasonStart       DateTime
  seasonEnd         DateTime
  status            String           @default("ACTIVE")
  enrollments       Enrollment[]
  triggerEvents     TriggerEvent[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @default(now()) @updatedAt
}

model Enrollment {
  id            String         @id @default(cuid())
  farmerId      String
  farmer        Farmer         @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  policyId      String
  policy        Policy         @relation(fields: [policyId], references: [id], onDelete: Cascade)
  farmId        String // Specific farm covered
  farm          Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  status        String         @default("ACTIVE")
  payouts       Payout[]
  triggerEvents TriggerEvent[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
}

model RainfallReading {
  id           String   @id @default(cuid())
  farmId       String
  farm         Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  date         DateTime
  dailyMm      Float
  cumulativeMm Float
  periodDays   Int
  createdAt    DateTime @default(now())

  @@unique([farmId, date])
}

model TriggerEvent {
  id               String     @id @default(cuid())
  policyId         String
  policy           Policy     @relation(fields: [policyId], references: [id], onDelete: Cascade)
  farmId           String
  farm             Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  enrollmentId     String
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  dateTriggered    DateTime   @default(now())
  rainfallRecorded Float
  thresholdMm      Float
  payoutAmount     Float
  severity         String // WARNING, SEVERE
  status           String     @default("PENDING_APPROVAL")
}

model Payout {
  id             String     @id @default(cuid())
  enrollmentId   String
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id])
  amount         Float
  status         String     @default("PENDING") // PENDING, APPROVED, REJECTED, PAID
  dateCalculated DateTime   @default(now())
  updatedAt      DateTime   @default(now()) @updatedAt
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String // email or phone
  token      String   @unique
  type       String   @default("SETUP") // SETUP, OTP
  role       String? // the role they are assigned or logging in as
  expires    DateTime
  createdAt  DateTime @default(now())
}
